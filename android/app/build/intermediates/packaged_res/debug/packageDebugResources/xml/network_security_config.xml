<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext only for local development (emulator) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.108.119.232</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
    <!-- Production: Certificate pinning for the backend server -->
    <!-- Uncomment and add your server's SHA-256 pin before release:
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">your-server.com</domain>
        <pin-set expiration="2027-01-01">
            <pin digest="SHA-256">YOUR_BASE64_PIN_HERE==</pin>
        </pin-set>
    </domain-config>
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
