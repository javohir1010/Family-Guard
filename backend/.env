SECRET_KEY=django-insecure-change-this-in-production-use-random-50-char-string

DEBUG=True

ALLOWED_HOSTS=*,localhost,127.0.0.1,0.0.0.0

# Database
POSTGRES_DB=familyguard
POSTGRES_USER=familyguard
POSTGRES_PASSWORD=familyguard_secret
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# Twilio (SOS SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
EMERGENCY_PHONE_NUMBER=+998901234567

# Firebase FCM
FIREBASE_CREDENTIALS_FILE=/app/firebase-credentials.json

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Invite code TTL (seconds)
INVITE_CODE_TTL=86400
